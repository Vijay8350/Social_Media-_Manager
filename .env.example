# ---------------------------------------------------------------------------
# Insta Post Generator — environment variables
# Copy to .env (and apps/web/.env.local for Next.js) and fill in real values.
# Never commit the filled-in .env. Server-side only unless prefixed NEXT_PUBLIC_.
# ---------------------------------------------------------------------------

# --- Supabase (hosted cloud project) ---------------------------------------
# Project URL + anon key are safe for the browser; service role key is SECRET.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key   # worker only; bypasses RLS

# --- Text generation: DeepSeek ---------------------------------------------
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com                 # override to swap text provider endpoint
DEEPSEEK_MODEL=deepseek-chat

# --- Image generation + vision quality gate: Google Gemini -----------------
# One key serves both image generation and the vision read-back.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_VISION_MODEL=gemini-2.5-flash

# --- Instagram / Meta (Facebook Login OAuth + Graph API) -------------------
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:3000/api/instagram/callback
FACEBOOK_GRAPH_VERSION=v21.0
# Optional: override requested OAuth scopes (comma-separated). Drop
# instagram_content_publish here until the Instagram product is added to the app.
# Default: instagram_basic,instagram_content_publish,pages_show_list,pages_read_engagement,business_management
# FACEBOOK_SCOPES=instagram_basic,pages_show_list,pages_read_engagement

# --- Background jobs: Redis -------------------------------------------------
# On a SHARED server (other projects present), isolate this app's keys:
#  - use a dedicated db index, e.g. redis://localhost:6379/3
#  - BULLMQ_PREFIX namespaces all queue keys (default "insta")
REDIS_URL=redis://localhost:6379
BULLMQ_PREFIX=insta

# --- Billing: Stripe (wired in M9; placeholders until then) ----------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx

# --- Security / pipeline ----------------------------------------------------
# 32-byte key, base64-encoded. Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=base64-encoded-32-byte-key
MAX_REGEN_ATTEMPTS=3

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Port the web app listens on (kept off 3000 to avoid clashing on a shared box).
WEB_PORT=3200
